{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Electron (Main Process)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": ["--inspect=5858", "."],
      "env": {
        "ELECTRON_ENABLE_LOGGING": "1",
        "VITE_DEV_MODE": "true"
      },
      "skipFiles": ["<node_internals>/**"],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "preLaunchTask": "npm: build",
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "resolveSourceMapLocations": ["${workspaceFolder}/**", "!**/node_modules/**"],
      "sourceMaps": true
    },
    {
      "name": "Debug Android (Launch & Debug)",
      "type": "android",
      "request": "launch",
      "appSrcRoot": "${workspaceFolder}/android/app/src/main",
      "apkFile": "${workspaceFolder}/android/app/build/outputs/apk/debug/app-debug.apk",
      "launchActivity": "com.increvise.app.MainActivity",
      "adbPort": 5037,
      "preLaunchTask": "android:build"
    },
    {
      "name": "Debug Android (Attach Only)",
      "type": "android",
      "request": "attach",
      "appSrcRoot": "${workspaceFolder}/android/app/src/main",
      "apkFile": "${workspaceFolder}/android/app/build/outputs/apk/debug/app-debug.apk",
      "adbPort": 5037,
      "processId": "${command:PickAndroidProcess}"
    }
  ]
}
