{
  "name": "Increvise",
  "version": "0.1.0",
  "description": "Revise your local files with spaced repetition.",
  "license": "GPL-3.0-or-later",
  "author": "",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_MODE=true electron-vite build && electron-rebuild -f -w better-sqlite3 && electron-vite dev",
    "dev:noserver": "cross-env VITE_DEV_MODE=true electron-vite build && electron-rebuild -f -w better-sqlite3 && electron .",
    "build": "electron-vite build && electron-rebuild -f -w better-sqlite3 ",
    "preview": "electron-vite preview",
    "prestart": "electron-rebuild -f -w better-sqlite3",
    "start": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "test": "npm run rebuild:node && node --test test/",
    "test:validation": "npm run rebuild:node && node --test test/validation.test.js",
    "test:incremental": "npm run rebuild:node && node --test test/incremental.test.js",
    "test:spaced": "npm run rebuild:node && node --test test/spaced.test.js",
    "test:workspace": "npm run rebuild:node && node --test test/workspace.test.js",
    "test:clean": "rm -rf test/test-workspace && rm -rf test/temp-test-workspace",
    "db:rollback": "npm run rebuild:node && node scripts/rollback.js",
    "dist": "npm run build && electron-builder",
    "dist:appimage": "npm run build && electron-builder --linux AppImage",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dev:mobile": "vite --config vite.config.mobile.js",
    "build:mobile": "vite build --config vite.config.mobile.js",
    "sync:mobile": "npm run build:mobile && npx cap sync",
    "android": "npm run sync:mobile && npx cap run android",
    "android:build": "npm run sync:mobile && cd android && ./gradlew assembleDebug",
    "android:release": "npm run sync:mobile && cd android && ./gradlew assembleRelease"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.2",
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.39.1",
    "cross-env": "^10.1.0",
    "electron": "^38.2.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.1.1",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "prettier": "3.6.2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/cli": "^7.4.5",
    "@capacitor/core": "^8.0.2",
    "@capacitor/filesystem": "^8.1.0",
    "@capgo/capacitor-file-picker": "^8.1.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.8",
    "@ionic/core": "^8.8.3",
    "@lion/ui": "^0.16.1",
    "@shoelace-style/shoelace": "^2.20.1",
    "better-sqlite3": "^12.4.1",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.1",
    "lit": "^3.3.1",
    "marked": "^17.0.1",
    "node-fetch": "^3.3.2",
    "node-html-markdown": "^2.0.0",
    "pdfjs-dist": "^5.4.449"
  },
  "build": {
    "appId": "com.increvise.app",
    "productName": "Increvise",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "index.html",
      "style.css",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Education",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education",
      "icon": "resources/icon.icns"
    },
    "dmg": {
      "title": "Increvise ${version}",
      "icon": "resources/icon.icns"
    },
    "appImage": {},
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
